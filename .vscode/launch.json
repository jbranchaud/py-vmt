{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-s"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-s"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Attach to debugpy",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "localhost", "port": 5678 }
    }
  ]
}
